-- Enhanced hover/press effects
local function tweenBtn(btn, enter, press)
    local goal
    if press then
        goal = {Size = btn.Size - UDim2.new(0, 4, 0, 4), BackgroundColor3 = btn.BackgroundColor3:Lerp(Color3.new(0,0,0), 0.1)}
    elseif enter then
        goal = {BackgroundColor3 = btn.BackgroundColor3:Lerp(Color3.new(1,1,1), 0.2)}
    else
        goal = {Size = btn.Size, BackgroundColor3 = btn.BackgroundColor3}
    end
    TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), goal):Play()
end

for _, btn in {SubmitBtn, GetKeyBtn, DiscordBtn} do
    btn.MouseEnter:Connect(function() tweenBtn(btn, true) end)
    btn.MouseLeave:Connect(function() tweenBtn(btn, false) end)
    btn.MouseButton1Down:Connect(function() tweenBtn(btn, false, true) end)
    btn.MouseButton1Up:Connect(function() tweenBtn(btn, true) end)
end

-- Status helper with shake on error (new!)
local function setStatus(text, color, shake)
    Subtitle.Text = text
    Subtitle.TextColor3 = color or Color3.fromRGB(190, 190, 210)
    if shake then
        local originalPos = Frame.Position
        for i = 1, 5 do
            Frame.Position = originalPos + UDim2.new(0, math.random(-2,2), 0, math.random(-2,2))
            wait(0.05)
        end
        Frame.Position = originalPos
    end
end

-- Verify key with loading spinner
local function verifyKey()
    -- Show spinner
    SpinnerFrame.Visible = true
    local spinTween = TweenService:Create(Spinner, TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut), {Rotation = 360})
    spinTween:Play()
    spinTween.Completed:Connect(function() spinTween:Play() end)  -- Loop

    wait(1)  -- Simulate check (adjust if needed)

    local input = InputBox.Text
    if input == CORRECT_KEY then
        SpinnerFrame.Visible = false
        spinTween:Stop()
        setStatus("Verifying...", Color3.fromRGB(100, 255, 100))
        wait(0.5)
        -- Fade out GUI
        TweenService:Create(Frame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
        for _, child in Frame:GetChildren() do
            if child:IsA("GuiObject") then
                TweenService:Create(child, TweenInfo.new(0.5), {BackgroundTransparency = 1, TextTransparency = 1, ImageTransparency = 1}):Play()
            end
        end
        wait(0.5)
        ScreenGui:Destroy()
        StarterGui:SetCore("SendNotification", {
            Title = "Access Granted",
            Text = "Loading script...",
            Duration = 4
        })
        runMainScript()  -- runs the new loadstring
    else
        SpinnerFrame.Visible = false
        spinTween:Stop()
        setStatus("Invalid Key – Try Again", Color3.fromRGB(255, 90, 90), true)  -- with shake
        wait(2.5)
        setStatus("Enter your key to continue")
    end
end

